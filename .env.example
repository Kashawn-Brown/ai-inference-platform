# Database — async URL for the runtime, sync URL for Alembic migrations.
# Default values match the docker-compose Postgres service.
DATABASE_URL=postgresql+asyncpg://aiinfra:aiinfra@postgres:5432/aiinfra
DATABASE_URL_SYNC=postgresql+psycopg://aiinfra:aiinfra@postgres:5432/aiinfra

# vLLM — base URL inside the Compose network, model name, and per-request timeout from the gateway.
VLLM_BASE_URL=http://vllm:8000
VLLM_MODEL_NAME=Qwen/Qwen2.5-1.5B-Instruct
VLLM_TIMEOUT_MS=30000

# Logging — structured JSON to stdout in containers; switch LOG_FORMAT for human-readable local output.
LOG_LEVEL=INFO
LOG_FORMAT=json

# Worker — how often the loop polls Postgres for claimable items, and how many to claim per iteration.
WORKER_POLL_INTERVAL_MS=500
WORKER_BATCH_CLAIM_SIZE=1

# Metrics — separate Prometheus scrape ports for gateway and worker.
METRICS_PORT_GATEWAY=9100
METRICS_PORT_WORKER=9101
